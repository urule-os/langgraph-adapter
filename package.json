    "@urule/auth-middleware": "file:../urule-auth-middleware",
    "fastify": "^5.0.0",
    "nats": "^2.28.0",
    "ulid": "^2.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
